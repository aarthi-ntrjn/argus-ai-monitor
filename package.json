{
  "name": "argus-ai-hub",
  "version": "0.1.6",
  "description": "Your command center for Claude Code and GitHub Copilot CLI sessions. Watch every session live, send commands, and stop runaway agents, all from a single browser tab.",
  "license": "MIT",
  "homepage": "https://github.com/aarthi-ntrjn/argus#readme",
  "bugs": {
    "url": "https://github.com/aarthi-ntrjn/argus/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "bin": {
    "argus": "./bin/argus.js",
    "argus-ai-hub": "./bin/argus.js"
  },
  "directories": {
    "doc": "docs",
    "test": "frontend/tests"
  },
  "files": [
    "bin/",
    "backend/dist/",
    "frontend/dist/",
    "CHANGELOG.md"
  ],
  "keywords": [
    "claude-code",
    "copilot",
    "ai",
    "session-monitor",
    "developer-tools",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aarthi-ntrjn/argus.git"
  },
  "author": "aarthi-ntrjn",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=backend",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "prepublishOnly": "npm run build",
    "test:e2e": "npm run test:e2e --workspace=frontend",
    "test:e2e:real": "npm run test:e2e:real --workspace=frontend",
    "test:e2e:ui": "npm run test:e2e:ui --workspace=frontend",
    "test:e2e:real:ui": "npm run test:e2e:real:ui --workspace=frontend"
  },
  "dependencies": {
    "@fastify/static": "9.0.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@fastify/websocket": "11.2.0",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "better-sqlite3": "12.8.0",
    "chokidar": "3.6.0",
    "dotenv": "^17.4.2",
    "fastify": "5.8.4",
    "js-yaml": "4.1.1",
    "node-pty": "^1.1.0",
    "pino": "9.14.0",
    "pino-pretty": "11.3.0",
    "ps-list": "8.1.1",
    "uuid": "9.0.1",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "vitest": "3.1.1"
  },
  "overrides": {
    "vitest": {
      "vite": "6.4.2"
    }
  }
}
