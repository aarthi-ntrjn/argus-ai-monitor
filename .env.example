# Argus environment variables
# Copy to .env and fill in values as needed.

# Override the telemetry ingest endpoint. Leave blank (or omit entirely) to use
# the default PostHog endpoint hardcoded in telemetry-service.ts.
# Set to empty string to disable outbound telemetry entirely.
# TELEMETRY_URL=

# Microsoft Teams integration
# Auth credentials read automatically by @microsoft/teams.apps SDK
# CLIENT_ID=        (Azure App Registration client ID)
# CLIENT_SECRET=    (Azure App Registration client secret)
# TENANT_ID=        (Azure AD tenant ID)
#
# Channel config (overrides ~/.argus/teams-config.json when set)
# TEAMS_ENABLED=true
# TEAMS_TEAM_ID=
# TEAMS_CHANNEL_ID=
# TEAMS_OWNER_AAD_OBJECT_ID=

# Slack integration
# Bot User OAuth Token from your Slack App (xoxb-...)
# SLACK_BOT_TOKEN=
#
# App-level token for Socket Mode (xapp-...) - required only for Slack-to-Argus routing
# SLACK_APP_TOKEN=
#
# Channel ID (e.g. C01234ABCDE) where Argus will post session notifications
# SLACK_CHANNEL_ID=
