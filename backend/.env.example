# Log level for the backend server.
# Options: debug | info | warn | error | silent
# Default: info
LOG_LEVEL=info

# Slack integration (optional)
# Bot User OAuth Token from your Slack App (xoxb-...)
SLACK_BOT_TOKEN=

# App-level token for Socket Mode (xapp-...) - required only for Slack-to-Argus routing (US4)
SLACK_APP_TOKEN=

# Channel ID (e.g. C01234ABCDE) where Argus will post session notifications
SLACK_CHANNEL_ID=
